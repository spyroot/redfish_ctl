{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://redfish-ctl/schemas/gates.schema.json",
  "title": "Gate registry",
  "description": "Canonical registry of every mandatory gate (gates/manifest.yaml).",
  "type": "object",
  "required": [
    "version",
    "runner_tag",
    "required_jobs",
    "mandatory_ids",
    "gates"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "runner_tag": {
      "type": "string",
      "minLength": 1
    },
    "required_jobs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "mandatory_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(\\.[a-z0-9-]+)+$"
      }
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "profile",
          "command",
          "required",
          "mutates"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(\\.[a-z0-9-]+)+$"
          },
          "profile": {
            "type": "string",
            "enum": [
              "merge",
              "integration",
              "deploy",
              "repository-export"
            ]
          },
          "command": {
            "type": "string",
            "pattern": "^scripts/gates/.+\\.sh$"
          },
          "required": {
            "type": "boolean"
          },
          "mutates": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
